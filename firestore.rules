rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Come collection — restaurants/places
    match /come/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Chefs directory
    match /chefs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Chef nominations from users
    match /chef_nominations/{document=**} {
      allow read, write: if true;
    }
    // News articles
    match /news/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Culinary guides
    match /guides/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Special awards
    match /premios_especiales/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
