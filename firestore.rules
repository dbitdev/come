rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for business leads and chef nominations
    match /business_leads/{document=**} {
      allow read, write: if true;
    }
    match /chef_nominations/{document=**} {
      allow read, write: if true;
    }
    match /chefs/{document=**} {
      allow read, write: if true;
    }
    match /news/{document=**} {
      allow read, write: if true;
    }
  }
}
